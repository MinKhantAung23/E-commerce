{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2023",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "types": ["node"],
    "rootDir": ".",
    "outDir": "dist",
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0"
  },
   "include": ["src", "prisma.config.ts"]
}